# ============================================================
# LingServer Dashboard — 环境变量模板
# 复制为 .env 并修改实际值
# cp .env.example .env
# ============================================================

# ── 安全（生产环境务必修改） ──
LING_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LING_ACCESS_EXPIRE_HOURS=24
LING_REFRESH_EXPIRE_DAYS=7
LING_BCRYPT_COST=12
LING_MAX_LOGIN_FAILURES=5
LING_LOGIN_LOCKOUT_MINUTES=15
LING_ADMIN_PASSWORD=   # 留空则自动生成随机密码，首次登录后须修改

# ── 限流 ──
LING_RATE_GLOBAL=60/minute
LING_RATE_LOGIN=10/minute

# ── 服务器 ──
LING_HOST=0.0.0.0
LING_PORT=8899
LING_DEBUG=false

# ── 数据库路径 ──
LING_DB_PATH=ling-server.db

# ── 文件管理 ──
LING_FILE_PREVIEW_MB=10
LING_FILE_UPLOAD_MB=500
LING_FILE_WHITELIST=/home,/var,/etc,/opt,/tmp,/usr,/srv

# ── 日志 ──
LING_LOG_TAIL=500
LING_LOG_MAX_MB=100
LING_LOG_SOURCES=[{"id":"syslog","path":"/var/log/syslog","label":"Syslog"},{"id":"auth","path":"/var/log/auth.log","label":"Auth Log"}]

# ── 终端 ──
LING_TERM_MAX_SESSIONS=5
LING_TERM_TIMEOUT=30

# ── Docker ──
DOCKER_HOST=unix:///var/run/docker.sock

# ── 指标采集 ──
LING_METRICS_RETENTION=7
LING_METRICS_INTERVAL=60
